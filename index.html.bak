<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Machine Learning Engineer & MLOps Specialist - Building scalable, observable, and reliable AI pipelines on cloud-native stacks">
    <meta name="keywords" content="Machine Learning, MLOps, ML Engineer, Cloud, Kubernetes, AI, Portfolio">
    <title>Rubaiyat Emon | Machine Learning Engineer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&family=Fira+Code:wght@400;500;600&family=Exo+2:wght@400;600;700;800&family=Montserrat:wght@400;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container nav-container">
            <a href="#" class="logo">
                <span class="logo-bracket">&lt;</span>
                <span class="logo-text" data-value="Rubaiyat Emon">Rubaiyat Emon</span>
                <span class="logo-bracket">/&gt;</span>
            </a>
            <ul class="nav-menu">
                <li><a href="#projects" class="nav-link">Projects</a></li>
                <li><a href="#skills" class="nav-link">Skills</a></li>
                <li><a href="#contact" class="nav-link cta-button">Contact</a></li>
                <li class="theme-toggle-item">
                    <button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle light/dark theme">
                        <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="5"></circle>
                            <line x1="12" y1="1" x2="12" y2="3"></line>
                            <line x1="12" y1="21" x2="12" y2="23"></line>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                            <line x1="1" y1="12" x2="3" y2="12"></line>
                            <line x1="21" y1="12" x2="23" y2="12"></line>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                        </svg>
                        <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                        </svg>
                    </button>
                </li>
            </ul>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle Dark/Light Mode">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path class="sun-icon"
                        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
                    </path>
                    <path class="moon-icon" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" style="display:none;">
                    </path>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-container">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="hero-name">Rubaiyat Emon</span>
                    <span class="hero-role">Machine Learning Engineer</span>
                </h1>
                <p class="hero-subtitle">
                    From Mechanical Systems to Machine Learning Systems.<br>
                    Architecting scalable, observable, and reliable AI pipelines on cloud-native stacks.
                </p>
                <div class="hero-tagline">
                    <span class="tagline-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                        </svg>
                    </span>
                    <span id="rotating-tagline" class="rotating-text">Building End-to-End ML Pipelines</span>
                </div>
                <div class="hero-cta">
                    <a href="#projects" class="btn btn-primary">View Portfolio Projects</a>
                    <a href="resume.pdf" class="btn btn-secondary" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Resume
                    </a>
                </div>
            </div>
            <div class="system-canvas">
                <svg id="hero-pipeline-svg" class="hero-pipeline-svg">
                </svg>
                <div class="nodes-container">
                    <div class="pipeline-node" id="hero-node-ingest" data-node="ingest">
                        <div class="node-icon">📡</div>
                        <div class="node-info">
                            <div class="node-status">Nominal</div>
                            <div class="node-label">Ingest</div>
                        </div>
                    </div>
                    <div class="pipeline-node" id="hero-node-feature-store" data-node="feature">
                        <div class="node-icon">🗄️</div>
                        <div class="node-info">
                            <div class="node-status">Nominal</div>
                            <div class="node-label">Feature Store</div>
                        </div>
                    </div>
                    <div class="pipeline-node" id="hero-node-train" data-node="train">
                        <div class="node-icon">🧠</div>
                        <div class="node-info">
                            <div class="node-status">Nominal</div>
                            <div class="node-label">Train</div>
                        </div>
                    </div>
                    <div class="pipeline-node" id="hero-node-registry" data-node="registry">
                        <div class="node-icon">🏷️</div>
                        <div class="node-info">
                            <div class="node-status">Nominal</div>
                            <div class="node-label">Registry</div>
                        </div>
                    </div>
                    <div class="pipeline-node" id="hero-node-deploy" data-node="deploy">
                        <div class="node-icon">🚀</div>
                        <div class="node-info">
                            <div class="node-status">Nominal</div>
                            <div class="node-label">Deploy</div>
                        </div>
                    </div>
                </div>
                <div class="telemetry-terminal">
                    <div class="terminal-header">
                        <span class="terminal-dot red"></span>
                        <span class="terminal-dot yellow"></span>
                        <span class="terminal-dot green"></span>
                        <span class="terminal-title">SYSTEM MONITOR</span>
                    </div>
                    <div id="hero-telemetry-logs" class="terminal-body">
                        <div class="log-line">[INFO] Initializing Pipeline Map...</div>
                        <div class="log-line">[SYSTEM] MLOps Engine v4.2.0 active</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects-section">
        <div class="container">
            <h2 class="section-title">
                <span class="title-accent">The Four Pillars</span>
                Portfolio Projects
            </h2>
            <p class="section-subtitle">Production-grade ML systems demonstrating end-to-end engineering excellence</p>

            <div class="filter-container">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="mlops">MLOps</button>
                <button class="filter-btn" data-filter="genai">GenAI</button>
                <button class="filter-btn" data-filter="vision">Computer Vision</button>
            </div>

            <div class="projects-grid">
                <!-- Project A: Fraud Detection -->
                <article class="project-card" data-project="fraud" data-category="mlops">
                    <div class="project-header">
                        <div class="project-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                            </svg>
                        </div>
                        <span class="project-tag">Speed & Reliability</span>
                    </div>
                    <h3 class="project-title">Real-Time Fraud Detection System</h3>
                    <p class="project-description">
                        Low-latency fraud detection API processing 10,000+ TPS with sub-150ms P95 latency,
                        featuring zero-downtime Blue/Green deployments and automated drift monitoring.
                    </p>
                    <div class="project-tech">
                        <span class="tech-badge">Kafka</span>
                        <span class="tech-badge">Feast</span>
                        <span class="tech-badge">MLflow</span>
                        <span class="tech-badge">FastAPI</span>
                        <span class="tech-badge">Prometheus</span>
                        <span class="tech-badge">Evidently AI</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <div class="stat-value">&lt;120ms</div>
                            <div class="stat-label">P95 Latency</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">-18%</div>
                            <div class="stat-label">False Positives</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">Zero</div>
                            <div class="stat-label">Downtime</div>
                        </div>
                    </div>
                    <button class="btn btn-outline project-btn">View Details</button>
                </article>

                <!-- Project B: Recommendation Engine -->
                <article class="project-card" data-project="recommendation" data-category="mlops">
                    <div class="project-header">
                        <div class="project-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path
                                    d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2">
                                </path>
                            </svg>
                        </div>
                        <span class="project-tag">Distributed Scale</span>
                    </div>
                    <h3 class="project-title">Scalable Recommendation Engine</h3>
                    <p class="project-description">
                        Personalized news recommendation system with distributed training on 100GB+ datasets,
                        autoscaling serving layer, and Kubeflow-orchestrated retraining pipelines.
                    </p>
                    <div class="project-tech">
                        <span class="tech-badge">Kubernetes</span>
                        <span class="tech-badge">Ray Train</span>
                        <span class="tech-badge">Ray Serve</span>
                        <span class="tech-badge">Kubeflow</span>
                        <span class="tech-badge">Terraform</span>
                        <span class="tech-badge">EKS</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <div class="stat-value">70%</div>
                            <div class="stat-label">Training Speedup</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">2-15</div>
                            <div class="stat-label">Auto-scaling Pods</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">10x</div>
                            <div class="stat-label">Dataset Growth</div>
                        </div>
                    </div>
                    <button class="btn btn-outline project-btn">View Details</button>
                </article>

                <!-- Project C: LLM & RAG -->
                <article class="project-card" data-project="llm" data-category="genai">
                    <div class="project-header">
                        <div class="project-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                        </div>
                        <span class="project-tag">GenAI System</span>
                    </div>
                    <h3 class="project-title">Enterprise LLM & RAG Platform</h3>
                    <p class="project-description">
                        Retrieval-Augmented Generation system grounding LLMs on 500k+ engineering documents,
                        with fine-tuned embeddings, vector search, and rigorous evaluation pipelines.
                    </p>
                    <div class="project-tech">
                        <span class="tech-badge">LangChain</span>
                        <span class="tech-badge">Qdrant</span>
                        <span class="tech-badge">LoRA</span>
                        <span class="tech-badge">Transformers</span>
                        <span class="tech-badge">Redis</span>
                        <span class="tech-badge">RAGAS</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <div class="stat-value">92%</div>
                            <div class="stat-label">Faithfulness</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">40%</div>
                            <div class="stat-label">Improvement</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">60%</div>
                            <div class="stat-label">Latency Reduction</div>
                        </div>
                    </div>
                    <button class="btn btn-outline project-btn">View Details</button>
                </article>

                <!-- Project D: Computer Vision -->
                <article class="project-card" data-project="vision" data-category="vision">
                    <div class="project-header">
                        <div class="project-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </div>
                        <span class="project-tag">Optimization</span>
                    </div>
                    <h3 class="project-title">Computer Vision for Edge Deployment</h3>
                    <p class="project-description">
                        Optimized YOLOv8 object detection for edge hardware with pruning, quantization,
                        and TensorRT, achieving 3x speedup while maintaining accuracy.
                    </p>
                    <div class="project-tech">
                        <span class="tech-badge">YOLOv8</span>
                        <span class="tech-badge">TensorRT</span>
                        <span class="tech-badge">Triton</span>
                        <span class="tech-badge">KFServing</span>
                        <span class="tech-badge">GitHub Actions</span>
                        <span class="tech-badge">OpenCV</span>
                    </div>
                    <div class="project-stats">
                        <div class="stat">
                            <div class="stat-value">65%</div>
                            <div class="stat-label">Size Reduction</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">3.5x</div>
                            <div class="stat-label">Speedup</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">&lt;1.5%</div>
                            <div class="stat-label">mAP Drop</div>
                        </div>
                    </div>
                    <button class="btn btn-outline project-btn">View Details</button>
                </article>
            </div>
        </div>
    </section>



    <!-- Skills Section -->
    <section id="skills" class="skills-section">
        <div class="container">
            <h2 class="section-title">
                <span class="title-accent">Technology Stack</span>
                Skills & Expertise
            </h2>

            <div id="holo-skills-container" class="skills-grid">
                <!-- Data-driven holographic cards will be rendered here -->
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
        <div class="container">
            <div class="about-grid">
                <div class="about-image">
                    <div class="image-placeholder">
                        <img src="profile.png" alt="Rubaiyat Emon" class="profile-photo">
                    </div>
                </div>
                <div class="about-content">
                    <h2 class="section-title">
                        <span class="title-accent">My Journey</span>
                        About Me
                    </h2>
                    <div class="about-text">
                        <p>
                            My path into Machine Learning Engineering wasn't a linear ascent; it was forged through
                            the debris of heavy failure and the quiet desperation of starting over. Coming from a
                            <strong>Mechanical Engineering</strong> background, I was trained in precision and
                            reliability,
                            yet the transition into production ML often felt like an impossible mountain. I’ve known
                            what it feels like to be utterly stuck—trapped in the gap between the logic I knew and
                            the complex, high-stakes code that seemed to reject my every effort. I failed, I iterated,
                            and I failed again.
                        </p>
                        <p>
                            In those moments of absolute uncertainty, I clung to a hope that was nearly unreasonable—a
                            singular, relentless drive to succeed where others might have turned back. Today, I don't
                            just build models; I <strong>architect the battle-hardened systems</strong> that serve them.
                            Because I’ve felt the sting of a failing pipeline, I’m obsessed with the robust
                            infrastructure, monitoring, and MLOps automation that turn statistical promise into an
                            unshakeable reality.
                        </p>

                        <blockquote class="engineering-quote">
                            "I’ve come to realize that my Mechanical Engineering background isn't a gap—it's my
                            foundational strength. It provided the rigorous training in systems design, failure mode
                            analysis, and constraint optimization that I now use to build bulletproof ML production
                            architectures."
                        </blockquote>
                    </div>
                    <a href="#contact" class="btn btn-primary">Let's Discuss Scalable ML Systems</a>
                </div>
            </div>
        </div>
    </section>


    <!-- Contact Section -->
    <section id="contact" class="contact-section">
        <div class="container">
            <h2 class="section-title">Let's Build Something Together</h2>
            <p class="section-subtitle">Open to opportunities in ML Engineering, MLOps, and AI Infrastructure</p>
            <div class="contact-links">
                <a href="mailto:rubaiyatemon16317@gmail.com" class="contact-link">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L12 9.573l8.073-6.08c1.618-1.214 3.927-.059 3.927 1.964z" />
                    </svg>
                    Rubaiyat Emon
                </a>
                <a href="https://linkedin.com/in/yourprofile" target="_blank" class="contact-link">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                    LinkedIn Profile
                </a>
                <a href="https://github.com/rubaiyatemon" target="_blank" class="contact-link">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                    </svg>
                    rubaiyatemon
                </a>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <div class="contact-form-container">
        <form id="contact-form" class="contact-form">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required placeholder="John Doe">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="john@example.com">
            </div>
            <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" required placeholder="Let's build something great..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary submit-btn">Send Message</button>
            <p class="form-status" id="form-status"></p>
        </form>
    </div>

    <!-- Live GitHub Activity -->
    <div class="github-activity">
        <h3 class="activity-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path
                    d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22">
                </path>
            </svg>
            Latest Open Source Activity
        </h3>
        <div id="github-feed" class="github-feed">
            <p>Loading recent commits...</p>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Rubaiyat Emon. Built with precision engineering principles.</p>
            <p class="footer-note">
            </p>
        </div>
    </footer>

    <!-- Project Modal -->
    <div id="project-modal" class="modal">
        <div class="modal-content">
            <button class="modal-close">&times;</button>
            <div id="modal-body"></div>
        </div>
    </div>

    <script src="script.js"></script>
</body>

</html>